#!/bin/bash
set -e

echo "=== CUSTOM ASSEMBLE START ==="

cd /tmp/src

chmod +x gradlew

./gradlew clean build -x test

echo "Finding correct JAR..."

JAR_FILE=$(ls build/libs/*.jar | grep -v plain | head -n 1)

echo "Using JAR: $JAR_FILE"

cp "$JAR_FILE" /tmp/app.jar

echo "=== CUSTOM ASSEMBLE DONE ==="